# =============================================================
# CareerBridge Django 环境变量模板
# 复制为 .env 并填入真实值
# 位置：gateai/.env
# =============================================================

# ── Django ───────────────────────────────────────────────────
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-here

# ── PostgreSQL ───────────────────────────────────────────────
# 注意：Django 读这几个单独变量，不读 DATABASE_URL
POSTGRES_DB=careerbridge
POSTGRES_USER=careerbridge_user
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ── Stripe（支付）────────────────────────────────────────────
# 测试环境用 sk_test_ / pk_test_ 开头的 key
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ── OpenAI（AI 功能，可选）───────────────────────────────────
# 不填则 AI 相关功能不可用，但服务可以启动
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

# ── Email（邮件服务，可选）───────────────────────────────────
# 开发环境默认用 console backend，不需要填
# 如需真实发送邮件（如密码重置），填 SendGrid key
EMAIL_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@careerbridge.com
EMAIL_FROM_NAME=CareerBridge
EMAIL_TEMPLATE_ID=

# ── Sentry（错误监控，可选）──────────────────────────────────
# 不填则不上报错误，不影响运行
SENTRY_DSN=

# ── 其他可选配置 ─────────────────────────────────────────────
NOTIFICATION_RETENTION_DAYS=180
